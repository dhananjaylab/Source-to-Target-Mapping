# Oracle Mapping Copilot — Environment Variables
# Copy to .env and fill in your values

# ── Gemini LLM ─────────────────────────────────────────────────────────────
# Get your key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── FastAPI Backend ─────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ── Streamlit Frontend ──────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000

# ── Oracle Source DB (production — not used in demo mode) ──────────────────
# SOURCE_DB_HOST=oracle-crm.company.com
# SOURCE_DB_PORT=1521
# SOURCE_DB_SERVICE=CRM_PROD
# SOURCE_DB_USER=crm_readonly
# SOURCE_DB_PASSWORD=your_password_here

# ── Oracle Target DB (production) ───────────────────────────────────────────
# TARGET_DB_HOST=oracle-dw.company.com
# TARGET_DB_PORT=1521
# TARGET_DB_SERVICE=DW_PROD
# TARGET_DB_USER=dw_readonly
# TARGET_DB_PASSWORD=your_password_here

# ── Mapping defaults ────────────────────────────────────────────────────────
DEFAULT_CONFIDENCE_THRESHOLD=0.40
DEFAULT_SAMPLE_ROWS=5
ENABLE_PII_MASKING=true
